{% from 'govuk/components/header/macro.njk' import govukHeader %}

{% macro headerComponent(t, user) %}
  {% set moneyClaimsUrl = 'https://www1.moneyclaims.service.gov.uk/' %}
  {% set navigationList = [
    {
      href: '/dashboard',
      text: t('COMMON.HEADER.MY_ACCOUNT'),
      active: false
    },
    {
      href: '/logout',
      text: t('COMMON.HEADER.SIGN_OUT'),
      active: false
    }
  ] if user else [

  ] %}
  {% block header %}
    {{ govukHeader({
      homepageUrl: 'https://www.gov.uk',
      containerClasses: 'govuk-width-container',
      serviceName:  t('COMMON.HEADER.MONEY_CLAIMS'),
      serviceUrl: '/dashboard',
      navigationClasses: 'govuk-!-display-inline float-right',
      navigation: navigationList,
      useTudorCrown: true
    }) }}
    <div class="govuk-width-container civil-header-money-claims-link">
      <a class="govuk-header__link" href="{{ moneyClaimsUrl }}">{{ t('COMMON.HEADER.MONEY_CLAIMS') }}</a>
    </div>
  {% endblock %}
{% endmacro %}
