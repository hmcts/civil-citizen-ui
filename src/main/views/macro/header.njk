{% from 'govuk/macros/logo.njk' import govukLogo %}

{% macro headerComponent(t, user, serviceName = null) %}
  {% block header %}
    <div class="civil-header">
      <div class="govuk-header">
        <div class="govuk-header__container govuk-width-container">
          <div class="govuk-header__logo">
            <a href="https://www.gov.uk" class="govuk-header__homepage-link">
              {{ govukLogo({
                classes: 'govuk-header__logotype',
                ariaLabelText: 'GOV.UK'
              }) }}
            </a>
          </div>
        </div>
      </div>
      <div class="civil-header__service">
        <div class="govuk-width-container civil-header__service-inner">
          <div class="civil-header__service-links">
            <a href="/dashboard" class="civil-header__service-name">
              {{ serviceName if serviceName else t('COMMON.HEADER.MONEY_CLAIMS') }}
            </a>
            {% if user %}
              <a class="civil-header__account-link" href="/dashboard">
                {{ t('COMMON.HEADER.MY_ACCOUNT') }}
              </a>
            {% endif %}
          </div>
          {% if user %}
            <div class="civil-header__actions">
              <a class="civil-header__logout-link" href="/logout">
                {{ t('COMMON.HEADER.SIGN_OUT') }}
              </a>
            </div>
          {% endif %}
        </div>
      </div>
    </div>
  {% endblock %}
{% endmacro %}
