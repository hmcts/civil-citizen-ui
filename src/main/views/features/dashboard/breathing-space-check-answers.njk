{% extends "claim-details-tpl-dashboard.njk" %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}
{% from "../../macro/csrf.njk" import csrfProtection %}
{% from "../../macro/heading-with-caption.njk" import headingWithCaption %}

{% block pageTitle %}
  {{ setPageTitle(t, pageTitle) }}
{% endblock %}

{% block nestedContent %}
  {{ headingWithCaption(t, 'PAGES.BREATHING_SPACE_ENTRY.PAGE_TITLE', 'PAGES.BREATHING_SPACE_ENTRY.CYA.HEADING') }}

  {{ govukSummaryList({
    rows: summaryRows
  }) }}

  <form method="post" novalidate>
    {{ csrfProtection(csrf) }}
    <div class="govuk-button-group">
      {{ govukButton({
        text: t('COMMON.BUTTONS.CONTINUE')
      }) }}
    </div>
    <p class="govuk-body">
      <a href="{{ cancelUrl }}" class="govuk-link">{{ t('COMMON.BUTTONS.CANCEL') }}</a>
    </p>
  </form>
{% endblock %}
