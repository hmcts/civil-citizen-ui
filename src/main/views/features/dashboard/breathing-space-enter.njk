{% extends "claim-details-tpl-dashboard.njk" %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/input/macro.njk" import govukInput %}
{% from "govuk/components/radios/macro.njk" import govukRadios %}
{% from "../../macro/csrf.njk" import csrfProtection %}
{% from "../../macro/heading-with-caption.njk" import headingWithCaption %}
{% from "../../macro/cancelLink.njk" import cancelLink %}

{% block pageTitle %}
  {{ setPageTitle(t, pageTitle) }}
{% endblock %}

{% block nestedContent %}
  {{ headingWithCaption(t, 'PAGES.BREATHING_SPACE_ENTRY.PAGE_TITLE', 'PAGES.BREATHING_SPACE_ENTRY.TYPE_AND_REFERENCE.HEADING') }}

  <form method="post" novalidate>
    {{ csrfProtection(csrf) }}

    {{ govukRadios({
      idPrefix: 'type',
      name: 'type',
      fieldset: {
        legend: {
          text: t('PAGES.BREATHING_SPACE_ENTRY.TYPE_AND_REFERENCE.TYPE_LEGEND'),
          classes: 'govuk-fieldset__legend--m'
        }
      },
      items: [
        {
          value: BreathingSpaceType.MENTAL_HEALTH,
          text: t('PAGES.BREATHING_SPACE_ENTRY.TYPE_AND_REFERENCE.TYPE_MENTAL_HEALTH'),
          checked: form.model.type === BreathingSpaceType.MENTAL_HEALTH
        },
        {
          value: BreathingSpaceType.STANDARD,
          text: t('PAGES.BREATHING_SPACE_ENTRY.TYPE_AND_REFERENCE.TYPE_STANDARD'),
          checked: form.model.type === BreathingSpaceType.STANDARD
        }
      ],
      errorMessage: {
        text: t(form.errorFor('type'))
      } if form.errorFor('type')
    }) }}

    {{ govukInput({
      id: 'reference',
      name: 'reference',
      value: form.model.reference,
      label: {
        text: t('PAGES.BREATHING_SPACE_ENTRY.TYPE_AND_REFERENCE.REFERENCE_LABEL'),
        classes: 'govuk-label--s'
      },
      hint: {
        text: t('PAGES.BREATHING_SPACE_ENTRY.TYPE_AND_REFERENCE.REFERENCE_HINT')
      },
      classes: 'govuk-input--width-20',
      errorMessage: {
        text: t(form.errorFor('reference'))
      } if form.errorFor('reference')
    }) }}

    <div class="govuk-button-group">
      {{ govukButton({
        text: t('COMMON.BUTTONS.CONTINUE')
      }) }}
      {{ cancelLink(cancelUrl, t) }}
    </div>
  </form>
{% endblock %}
