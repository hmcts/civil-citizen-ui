{% extends "claim-details-tpl-dashboard.njk" %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/date-input/macro.njk" import govukDateInput %}
{% from "../../macro/csrf.njk" import csrfProtection %}
{% from "../../macro/heading-with-caption.njk" import headingWithCaption %}
{% from "../../macro/cancelLink.njk" import cancelLink %}

{% block pageTitle %}
  {{ setPageTitle(t, pageTitle) }}
{% endblock %}

{% block nestedContent %}
  {{ headingWithCaption(t, 'PAGES.BREATHING_SPACE_ENTRY.PAGE_TITLE', 'PAGES.BREATHING_SPACE_ENTRY.START_DATE.HEADING') }}

  {% if isMentalHealth %}
    <p class="govuk-body">{{ t('PAGES.BREATHING_SPACE_ENTRY.START_DATE.INTRO_MENTAL_HEALTH') }}</p>
    <p class="govuk-body">{{ t('PAGES.BREATHING_SPACE_ENTRY.START_DATE.INTRO_MENTAL_HEALTH_REMAIN') }}</p>
  {% else %}
    <p class="govuk-body">{{ t('PAGES.BREATHING_SPACE_ENTRY.START_DATE.INTRO_STANDARD') }}</p>
  {% endif %}

  <form method="post" novalidate>
    {{ csrfProtection(csrf) }}

    {{ govukDateInput({
      id: 'startDate',
      fieldset: {
        legend: {
          text: t('PAGES.BREATHING_SPACE_ENTRY.START_DATE.DATE_LABEL'),
          classes: 'govuk-fieldset__legend--m'
        }
      },
      hint: {
        text: t('PAGES.BREATHING_SPACE_ENTRY.START_DATE.DATE_HINT', {
          date: today.getDate() + ' ' + (today.getMonth() + 1) + ' ' + today.getFullYear()
        })
      },
      items: [
        {
          classes: 'govuk-input--width-2',
          name: 'day',
          label: t('COMMON.DAY'),
          value: form.model.day
        },
        {
          classes: 'govuk-input--width-2',
          name: 'month',
          label: t('COMMON.MONTH'),
          value: form.model.month
        },
        {
          classes: 'govuk-input--width-4',
          name: 'year',
          label: t('COMMON.YEAR'),
          value: form.model.year
        }
      ]
    }) }}

    <div class="govuk-button-group">
      {{ govukButton({
        text: t('COMMON.BUTTONS.CONTINUE')
      }) }}
      <a href="{{ previousUrl }}" class="govuk-button govuk-button--secondary" data-module="govuk-button">
        {{ t('COMMON.BUTTONS.PREVIOUS') }}
      </a>
      {{ cancelLink(cancelUrl, t) }}
    </div>
  </form>
{% endblock %}
