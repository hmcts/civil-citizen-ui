{% extends "claim-details-tpl.njk" %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/input/macro.njk" import govukInput %}
{% from "govuk/components/details/macro.njk" import govukDetails %}
{% from "../../../macro/contact-us-for-help.njk" import contactUsForHelp with context %}
{% from "../../../macro/csrf.njk" import csrfProtection %}
{% from "../../../macro/error-summary-message.njk" import errorSummary %}
{% from "../../../macro/page-title.njk" import setPageTitle %}

{% block pageTitle %}
  {{ setPageTitle(t, 'PAGES.FIRST_CONTACT_CLAIM_REFERENCE.PAGE_TITLE') }}
{% endblock %}

{% block content %}
  <div class="govuk-width-container">
    <main class="govuk-main-wrapper" role="main">
      <div class="govuk-grid-row">
        <div class="govuk-grid-column-two-thirds">
          {% if form.hasErrors() %}
            {{ errorSummary(form.getErrors(), t) }}
          {% endif %}
          <h1 class="govuk-heading-l">{{ t('PAGES.FIRST_CONTACT_CLAIM_REFERENCE.TITLE') }}</h1>
          <p class="govuk-body-m">{{ t('PAGES.FIRST_CONTACT_CLAIM_REFERENCE.ENTER_CLAIM') }}</p>

          <form method="post" novalidate>
            {{ csrfProtection(csrf) }}
            {{ govukInput({
              id: "claimReferenceValue",
              name: "claimReferenceValue",
              value: form.model.claimReferenceValue,
              type: "text",
              classes: "govuk-!-width-one-half",
              spellcheck: false,
              label: {
                text: t("PAGES.FIRST_CONTACT_CLAIM_REFERENCE.CLAIM_NUMBER")
              },
              hint: {
                text: t("PAGES.FIRST_CONTACT_CLAIM_REFERENCE.CLAIM_NUMBER_HINT")
              },
              errorMessage: {
                text:t(form.errorFor('claimReferenceValue'))
              } if form.hasFieldError('claimReferenceValue')
            }) }}

            {{ govukDetails({
              summaryText: t('PAGES.FIRST_CONTACT_CLAIM_REFERENCE.HOW_IF_CLAIM_NUMBER_NOT_WORK'),
              html: t('PAGES.FIRST_CONTACT_CLAIM_REFERENCE.THE_LETTERS_IN_YOUR_CLAIM') + '<br><br>' +
                    t('PAGES.FIRST_CONTACT_CLAIM_REFERENCE.CHECK_THE_EMAIL_OR_LETTER') +
                    '<a href="https://www.gov.uk/respond-to-court-claim-for-money" rel="noreferrer noopener" target="_blank">' +
                    t('PAGES.FIRST_CONTACT_CLAIM_REFERENCE.READ_MORE_GUIDANCE') + '</a>' + '<br><br>' +
                    t('PAGES.FIRST_CONTACT_CLAIM_REFERENCE.IF_YOUR_CLAIM_NUMBER_STILL_NOT_WORK')
            }) }}

            <div class="govuk-form-group">
              {{ govukButton({
                text: t('COMMON.BUTTONS.SAVE_AND_CONTINUE')
              }) }}
              {{ contactUsForHelp(t) }}
            </div>
          </form>
        </div>
      </div>
    </main>
  </div>
{% endblock %}
