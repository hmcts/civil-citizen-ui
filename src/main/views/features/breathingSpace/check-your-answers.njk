{% extends "claim-details-tpl.njk" %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}
{% from "../../macro/page-title.njk" import setPageTitle %}
{% from "../../macro/csrf.njk" import csrfProtection %}
{% from "../../macro/contact-us-for-help.njk" import contactUsForHelp with context %}

{% set pageTitle = t('PAGES.CHECK_YOUR_ANSWERS.TITLE') %}

{% block pageTitle %}
  {{ setPageTitle(t, pageTitle) }}
{% endblock %}

{% block content %}
  <div class="govuk-width-container">
    <main class="govuk-main-wrapper" role="main">
      <div class="govuk-grid-row">
        <div class="govuk-grid-column-two-thirds">
          <h1 class="govuk-heading-l">{{ t('PAGES.CHECK_YOUR_ANSWERS.TITLE') }}</h1>

          {% for section in sections %}
            {% if section.title %}
              <h2 class="govuk-heading-m">{{ section.title }}</h2>
            {% endif %}
            {{ govukSummaryList({
              rows: section.summaryList.rows
            }) }}
          {% endfor %}

          <form method="post" novalidate>
            {{ csrfProtection(csrf) }}
            <div class="govuk-button-group">
              {{ govukButton({
                text: t('COMMON.BUTTONS.SUBMIT')
              }) }}
            </div>
          </form>
          {{ contactUsForHelp(t) }}
        </div>
      </div>
    </main>
  </div>
{% endblock %}
