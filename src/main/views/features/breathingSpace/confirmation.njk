{% extends "claim-details-tpl.njk" %}
{% from "govuk/components/panel/macro.njk" import govukPanel %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "../../macro/page-title.njk" import setPageTitle %}

{% set pageTitle = t('PAGES.BREATHING_SPACE_CONFIRMATION.PAGE_TITLE') %}

{% block pageTitle %}
  {{ setPageTitle(t, pageTitle) }}
{% endblock %}

{% block content %}
  <div class="govuk-width-container">
    <main class="govuk-main-wrapper" role="main">
      <div class="govuk-grid-row">
        <div class="govuk-grid-column-two-thirds">
          {{ govukPanel({
            titleText: t('PAGES.BREATHING_SPACE_CONFIRMATION.TITLE'),
            html: t('PAGES.BREATHING_SPACE_CONFIRMATION.PANEL_HTML', { claimId: claimId })
          }) }}

          <h2 class="govuk-heading-m">{{ t('PAGES.BREATHING_SPACE_CONFIRMATION.WHAT_HAPPENS_NEXT') }}</h2>
          <p class="govuk-body">{{ t('PAGES.BREATHING_SPACE_CONFIRMATION.NEXT_STEP_1') }}</p>

          <div class="govuk-button-group">
            {{ govukButton({
              text: t('COMMON.BUTTONS.GO_TO_ACCOUNT'),
              href: '/dashboard'
            }) }}
          </div>
        </div>
      </div>
    </main>
  </div>
{% endblock %}
