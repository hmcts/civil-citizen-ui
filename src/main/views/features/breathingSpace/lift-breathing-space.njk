{% extends "claim-details-tpl.njk" %}
{% from "govuk/components/date-input/macro.njk" import govukDateInput %}
{% from "govuk/components/textarea/macro.njk" import govukTextarea %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "../../macro/error-summary.njk" import errorSummary %}
{% from "../../macro/csrf.njk" import csrfProtection %}
{% from "../../macro/contact-us-for-help.njk" import contactUsForHelp %}
{% from "../../macro/page-title.njk" import setPageTitle %}

{% set pageTitle = 'PAGES.BREATHING_SPACE.LIFT.TITLE' %}
{{ setPageTitle(t, pageTitle) }}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      {{ errorSummary(form.getErrors(), t) }}
      <h1 class="govuk-heading-l">
        <span class="govuk-caption-l">{{ t('PAGES.BREATHING_SPACE.LIFT.CAPTION') }}</span>
        {{ t('PAGES.BREATHING_SPACE.LIFT.TITLE') }}
      </h1>

      <form method="post" novalidate>
        {{ csrfProtection(csrf) }}

        {{ govukDateInput({
          id: "date",
          namePrefix: "date",
          fieldset: {
            legend: {
              text: t('PAGES.BREATHING_SPACE.LIFT.WHEN_END'),
              isPageHeading: false,
              classes: "govuk-fieldset__legend--m"
            }
          },
          hint: {
            text: t('PAGES.BREATHING_SPACE.LIFT.DATE_HINT')
          },
          items: [
            {
              name: "day",
              classes: "govuk-input--width-2",
              value: form.model.day,
              attributes: {
                maxlength: "2"
              }
            },
            {
              name: "month",
              classes: "govuk-input--width-2",
              value: form.model.month,
              attributes: {
                maxlength: "2"
              }
            },
            {
              name: "year",
              classes: "govuk-input--width-4",
              value: form.model.year,
              attributes: {
                maxlength: "4"
              }
            }
          ],
          errorMessage: form.errorFor('date', t)
        }) }}

        {{ govukTextarea({
          name: "text",
          id: "text",
          label: {
            text: t('PAGES.BREATHING_SPACE.LIFT.WHY_LIFTED'),
            classes: "govuk-label--m"
          },
          value: form.model.text,
          errorMessage: form.errorFor('text', t)
        }) }}

        <div class="govuk-button-group">
          {{ govukButton({
            text: t('COMMON.BUTTONS.CONTINUE')
          }) }}
          <a class="govuk-link" href="#">{{ t('COMMON.BUTTONS.PREVIOUS') }}</a>
        </div>

        <p class="govuk-body">
          <a href="#" class="govuk-link">{{ t('COMMON.BUTTONS.CANCEL') }}</a>
        </p>
      </form>
    </div>
    <div class="govuk-grid-column-one-third">
      {{ contactUsForHelp(t) }}
    </div>
  </div>
{% endblock %}
