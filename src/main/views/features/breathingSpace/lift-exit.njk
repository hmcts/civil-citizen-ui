{% extends "claim-details-tpl-dashboard.njk" %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/radios/macro.njk" import govukRadios %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}
{% from "../../macro/csrf.njk" import csrfProtection %}
{% from "../../macro/page-title.njk" import setPageTitle %}
{% from "../../macro/support-links.njk" import supportLinks %}
{% from "../../macro/contact-us-for-help.njk" import contactUsForHelp with context %}

{% set pageTitle = 'PAGES.BREATHING_SPACE.LIFT.EXIT.TITLE' %}
{{ setPageTitle(t, pageTitle) }}

{% block content %}
<div class="govuk-grid-row">
  <div class="govuk-grid-column-two-thirds">
    {% if errors %}
      {{ govukErrorSummary({
        titleText: t('ERRORS.THERE_IS_A_PROBLEM'),
        errorList: errors.errorSummaryList
      }) }}
    {% endif %}

    <form method="post" novalidate>
      {{ csrfProtection(csrf) }}

      {{ govukRadios({
        idPrefix: 'option',
        name: 'option',
        classes: 'govuk-radios--inline',
        fieldset: {
          legend: {
            text: t('PAGES.BREATHING_SPACE.LIFT.EXIT.TITLE'),
            isPageHeading: true,
            classes: 'govuk-fieldset__legend--l'
          }
        },
        hint: {
          text: t('PAGES.BREATHING_SPACE.LIFT.EXIT.BODY')
        },
        errorMessage: errors.optionError if errors else undefined,
        items: [
          {
            value: 'yes',
            text: t('COMMON.VARIATION_2.YES')
          },
          {
            value: 'no',
            text: t('COMMON.VARIATION_2.NO')
          }
        ]
      }) }}

      <div class="govuk-button-group">
        {{ govukButton({
          text: t('COMMON.BUTTONS.CONTINUE')
        }) }}
      </div>
    </form>
  </div>
  <div class="govuk-grid-column-one-third">
    <div class="border-small-top"></div>
    {% if helpSupportLinks != null and helpSupportLinks.length %}
      {{ supportLinks(t, helpSupportTitle, helpSupportLinks) }}
    {% endif %}
    {{ contactUsForHelp(t) }}
  </div>
</div>
{% endblock %}
