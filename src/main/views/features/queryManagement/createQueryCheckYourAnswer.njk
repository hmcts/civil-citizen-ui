{% extends "claim-details-tpl-dashboard.njk" %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}
{% from "../../macro/heading-with-caption.njk" import headingWithCaption %}
{% from "../../macro/csrf.njk" import csrfProtection %}

{% block pageTitle %}
    {{ setPageTitle(t, title.heading) }}
{% endblock %}

{% block nestedContent %}
{{ headingWithCaption(t, title.caption, title.heading) }}
  {% if summaryRows %}
      <div class="govuk-!-margin-bottom-9 govuk-border-colour-border-top-1">
        <div class="govuk-form-group">
          {{ govukSummaryList({
            rows: summaryRows
          }) }}
        </div>
      </div>
    {% endif %}
  <form method="post" novalidate>
    {{ csrfProtection(csrf) }}
    <div class="govuk-button-group">
          {{ govukButton({
            text: t('PAGES.QM.SEND_MESSAGE_CYA.SEND_MESSAGE')
          }) }}
          <a href="{{ cancelUrl }}" class="govuk-link govuk-!-margin-left-2" rel="noreferrer noopener">{{ t('COMMON.BUTTONS.CANCEL') }}</a>
        </div>
      </form>

    {% if showCivilServiceDebug %}
      <hr class="govuk-section-break govuk-section-break--l govuk-section-break--visible">
      <h2 class="govuk-heading-m">Debug: civil-service error response</h2>
      <p class="govuk-body">Builds the normal check-your-answers payload, corrupts it, then submits to civil-service.</p>

      {% if civilServiceDebugError %}
        <div class="govuk-inset-text">
          <p class="govuk-body"><strong>HTTP status:</strong> {{ civilServiceDebugError.status or 'N/A' }}</p>
          <p class="govuk-body"><strong>Axios message:</strong> {{ civilServiceDebugError.message }}</p>
          <h3 class="govuk-heading-s">Corrupted request body sent</h3>
          <pre class="govuk-body">{{ civilServiceDebugError.requestBodyJson }}</pre>
          <h3 class="govuk-heading-s">Response body received</h3>
          <pre class="govuk-body">{{ civilServiceDebugError.responseBodyJson }}</pre>
        </div>
      {% endif %}

      <form method="post" novalidate>
        {{ csrfProtection(csrf) }}
        {{ govukButton({
          name: 'action',
          value: 'debugSubmitInvalidPayload',
          text: 'Submit corrupted payload to civil-service',
          classes: 'govuk-button--warning'
        }) }}
      </form>
    {% endif %}
    {% endblock %}
