{
  "compilerOptions": {
    "outDir": "./dist/",
    "module": "commonjs",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2022",
    "noImplicitAny": false,
    "moduleResolution": "node",
    "noUnusedLocals": true,
    "experimentalDecorators": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowJs": true,
    "strictNullChecks": false,
    "strictPropertyInitialization": false,
    "strictFunctionTypes": false,
    "noImplicitThis": false,
    "lib": [
      "ES2022",
      "dom"
    ],
    "baseUrl": "src/main",
    "paths": {
      "common/*": [
        "common/*"
      ],
      "models/*": [
        "common/models/*"
      ],
      "form/*": [
        "common/form/*"
      ],
      "modules/*": [
        "modules/*"
      ],
      "client/*": [
        "app/client/*"
      ],
      "routes/*": [
        "routes/*"
      ],
      "services/*": [
        "services/*"
      ]
    },
    "typeRoots": [
      "./node_modules/@types",
      "./typings"
    ]
  },
  "exclude": [
    "node_modules",
    "src/test",
    "**/*.test.ts",
    "**/*.spec.ts"
  ]
}
